{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "defaultMode": "bypassPermissions",
    "additionalDirectories": [
      "~/.dotfiles/claude-code/.claude/",
      "~/.gnupg/"
    ]
  },
  "enableAllProjectMcpServers": true,
  "hooks": {
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.dotfiles/claude-code/.claude/hooks/worktree_create.sh",
            "timeout": 120,
            "statusMessage": "Installing worktree dependencies..."
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.dotfiles/claude-code/.claude/statusline.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": false,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "playwright@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": false,
    "claude-code-setup@claude-plugins-official": false,
    "playground@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "*.github.com",
        "*.npmjs.org"
      ]
    },
    "excludedCommands": [
      "docker"
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
